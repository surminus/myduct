#!/bin/bash
set -euo pipefail

APPIMAGE="${HOME}/Applications/zen-x86_64.AppImage"
VERSION_FILE="${HOME}/.local/share/zen-browser/version"
CURRENT_VERSION=$(cat "${VERSION_FILE}" 2>/dev/null || echo "none")

echo "Checking Zen Browser version..."
LATEST_VERSION=$(curl -sf "https://api.github.com/repos/zen-browser/desktop/releases/latest" | jq -r '.tag_name')

if [ -z "${LATEST_VERSION}" ]; then
    echo "Failed to fetch latest version" >&2
    exit 1
fi

if [ "${CURRENT_VERSION}" = "${LATEST_VERSION}" ]; then
    echo "Zen Browser is up to date (${CURRENT_VERSION})"
    exit 0
fi

echo "Updating Zen Browser: ${CURRENT_VERSION} -> ${LATEST_VERSION}"

DOWNLOAD_URL="https://github.com/zen-browser/desktop/releases/download/${LATEST_VERSION}/zen-x86_64.AppImage"
TMP_FILE=$(mktemp /tmp/zen-XXXXXX.AppImage)

echo "Downloading from ${DOWNLOAD_URL}..."
curl -L --progress-bar -o "${TMP_FILE}" "${DOWNLOAD_URL}"
chmod +x "${TMP_FILE}"
mv "${TMP_FILE}" "${APPIMAGE}"

mkdir -p "$(dirname "${VERSION_FILE}")"
echo "${LATEST_VERSION}" > "${VERSION_FILE}"

echo "Zen Browser updated to ${LATEST_VERSION}"
